# ----------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------
PORT=5000
NODE_ENV=development

# URL of the frontend application allowed to access the API via CORS
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------
# AI & EXTERNAL APIS (For Phase 5)
# ----------------------------------------------------

# Provider of the LLM
LLM_PROVIDER=groq

# Authentication key for Groq LLM
GROQ_API_KEY=your_groq_api_key_here

# API Key for Tavily (Recent News)
TAVILY_API_KEY=your_tavily_api_key_here

# User Agent for SEC EDGAR API
SEC_USER_AGENT=your_email@example.com

# Global Request Timeout (in milliseconds)
REQUEST_TIMEOUT=30000
